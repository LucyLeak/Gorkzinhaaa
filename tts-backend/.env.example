# PostgreSQL connection (same as NEON_DATABASE_URL in the Python bot)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Server port
TTS_BACKEND_PORT=7000

# Polling interval in milliseconds
TTS_POLL_INTERVAL_MS=2000

# Path to audio files directory (relative to cwd, i.e. tts-backend/)
TTS_AUDIO_DIR=../data/tts_audio
